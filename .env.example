# ── Groq API (LLM generation) ──────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=1024
GROQ_TEMPERATURE=0.1

# ── Cohere API (embeddings + reranking) ───────────────────────────────────────
COHERE_API_KEY=your_cohere_api_key_here
COHERE_EMBED_MODEL=embed-english-v3.0
COHERE_RERANK_MODEL=rerank-english-v3.0

# ── Chunking ───────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Retrieval ──────────────────────────────────────────────────────────────────
TOP_K_RETRIEVE=10
TOP_K_RERANK=5

# ── File limits ────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50

# ── Grounding / Trust (v2) ─────────────────────────────────────────────────────
# Evidence score thresholds for confidence labels (0.0–1.0)
CONFIDENCE_HIGH_THRESHOLD=0.55
CONFIDENCE_MEDIUM_THRESHOLD=0.20
# Below this threshold the bot issues a soft refusal instead of calling the LLM
GROUNDING_REFUSAL_THRESHOLD=0.05
# Minimum rerank score to count a chunk as supporting evidence
MIN_SUPPORTING_SCORE=0.20
# Queries shorter than this many words get a "please rephrase" hint
MIN_QUERY_WORDS=2
